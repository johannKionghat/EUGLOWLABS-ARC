{
  "name": "euglowlabs-arc",
  "version": "0.0.0",
  "private": true,
  "description": "EuglowLabs ARC — Autonomous Resource Cloud. Monorepo.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf .turbo node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "rimraf": "6.0.1",
    "turbo": "2.3.3",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
