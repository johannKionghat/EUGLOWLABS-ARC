{
  "name": "@euglowlabs/arc-shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared types, schemas and utilities for EuglowLabs ARC.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "rimraf": "6.0.1",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  },
  "dependencies": {
    "zod": "^4.4.2"
  }
}
