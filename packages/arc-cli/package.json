{
  "name": "@euglowlabs/arc-cli",
  "version": "0.1.0-rc.3",
  "private": true,
  "description": "EuglowLabs ARC CLI — bootstrap and operate your self-hosted ARC stack.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "arc": "./dist/index.js"
  },
  "files": ["dist", "playbooks"],
  "scripts": {
    "gen:manifest": "node ../../scripts/generate-playbooks-manifest.mjs",
    "gen:templates-manifest": "node ../../scripts/generate-templates-manifest.mjs",
    "prebuild": "pnpm gen:manifest && pnpm gen:templates-manifest",
    "pretest": "pnpm gen:manifest && pnpm gen:templates-manifest",
    "pretypecheck": "pnpm gen:manifest && pnpm gen:templates-manifest",
    "build": "tsc -p tsconfig.json && node ./scripts/copy-templates.mjs",
    "build:bin": "node ./scripts/build-binaries.mjs",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo bin"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@euglowlabs/arc-shared": "workspace:*",
    "clipanion": "4.0.0-rc.4",
    "eta": "^4.6.0",
    "execa": "^9.6.1",
    "yaml": "^2.8.3",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "rimraf": "6.0.1",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
