# ============================================================================
# ⚠️  WARNING — local-ai-packaged credentials (managed by ARC ai-stack role)
# ============================================================================
#
# Generated automatically by `arc setup --apply` on first run.
# Subsequent runs PRESERVE this file (idempotent — see role's stat-then-template).
#
# DO NOT commit this file to git. DO NOT share it.
#
# 🚨 JWT_SECRET / ANON_KEY / SERVICE_ROLE_KEY below are upstream DEMO values
# (the trio is cryptographically linked — Supabase needs them coherent).
# Supabase works out-of-the-box with this trio for LOCAL / SSH-tunnel use.
#
# BEFORE exposing Supabase publicly (Caddy + DNS + Let's Encrypt), regenerate
# the 3 keys atomically:
#   https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# Then update this file and run: `arc setup --apply` to restart the stack.
#
# ============================================================================
# 🚨 OPERATIONAL WARNING:
# This file is the source of truth for ai-stack credentials.
# - DO NOT delete it manually — secrets regen will desync from Postgres data
#   (existing DB users authenticated with old POSTGRES_PASSWORD will be locked out).
# - DO NOT edit it without backing up first.
# - For full reset: stop stack, backup Postgres data, delete this file,
#   re-run `arc setup --apply`, then restore data with new credentials if needed.
# ============================================================================

############
# n8n credentials (random hex 64 — `openssl rand -hex 32` equivalent)
############
N8N_ENCRYPTION_KEY={{ lookup('password', '/dev/null length=64 chars=hexdigits') }}
N8N_USER_MANAGEMENT_JWT_SECRET={{ lookup('password', '/dev/null length=64 chars=hexdigits') }}

############
# Supabase Secrets
############
POSTGRES_PASSWORD={{ lookup('password', '/dev/null length=32 chars=ascii_letters,digits') }}

# ⚠️ JWT TRIO — DEMO upstream values (regen before public exposure, see header).
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD={{ lookup('password', '/dev/null length=32 chars=ascii_letters,digits') }}
POOLER_TENANT_ID=1000

############
# Supabase Storage (S3 protocol access keys — random hex)
############
GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=stub
S3_PROTOCOL_ACCESS_KEY_ID={{ lookup('password', '/dev/null length=32 chars=hexdigits') }}
S3_PROTOCOL_ACCESS_KEY_SECRET={{ lookup('password', '/dev/null length=64 chars=hexdigits') }}

############
# Neo4j (user/password format — separator `/` is mandatory)
############
NEO4J_AUTH=neo4j/{{ lookup('password', '/dev/null length=32 chars=ascii_letters,digits') }}

############
# Langfuse / Clickhouse / MinIO secrets
############
CLICKHOUSE_PASSWORD={{ lookup('password', '/dev/null length=32 chars=ascii_letters,digits') }}
MINIO_ROOT_PASSWORD={{ lookup('password', '/dev/null length=32 chars=ascii_letters,digits') }}
LANGFUSE_SALT={{ lookup('password', '/dev/null length=32 chars=ascii_letters,digits') }}
NEXTAUTH_SECRET={{ lookup('password', '/dev/null length=32 chars=ascii_letters,digits') }}
ENCRYPTION_KEY={{ lookup('password', '/dev/null length=64 chars=hexdigits') }}

############
# Caddy hostnames — left commented (ARC exposure handled by Coolify in 001b/c).
############
# N8N_HOSTNAME=n8n.yourdomain.com
# WEBUI_HOSTNAME=openwebui.yourdomain.com
# FLOWISE_HOSTNAME=flowise.yourdomain.com
# SUPABASE_HOSTNAME=supabase.yourdomain.com
# LANGFUSE_HOSTNAME=langfuse.yourdomain.com
# OLLAMA_HOSTNAME=ollama.yourdomain.com
# SEARXNG_HOSTNAME=searxng.yourdomain.com
# NEO4J_HOSTNAME=neo4j.yourdomain.com
# LETSENCRYPT_EMAIL=internal

############
# Database (verbatim from .env.example)
############
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres

############
# Supavisor (mostly verbatim; SECRET_KEY_BASE / VAULT_ENC_KEY regenerated)
############
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
SECRET_KEY_BASE={{ lookup('password', '/dev/null length=64 chars=ascii_letters,digits') }}
VAULT_ENC_KEY={{ lookup('password', '/dev/null length=32 chars=ascii_letters,digits') }}
POOLER_DB_POOL_SIZE=5

############
# API Proxy (Kong) — KONG_HTTP_PORT remapped 8000 → {{ arc_kong_http_port }}
# to avoid collision with Coolify (binds 8000 since 001b sub-task 1).
############
KONG_HTTP_PORT={{ arc_kong_http_port }}
KONG_HTTPS_PORT=8443

############
# PostgREST
############
PGRST_DB_SCHEMAS=public,storage,graphql_public

############
# Flowise auth (defaults — uncomment to require login)
############
#FLOWISE_USERNAME=your_username
#FLOWISE_PASSWORD=your_password

############
# Auth (GoTrue) — API_EXTERNAL_URL aligned with KONG_HTTP_PORT remap
############
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
API_EXTERNAL_URL=http://localhost:{{ arc_kong_http_port }}

## Mailer Config
MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

## Email auth
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender
ENABLE_ANONYMOUS_USERS=false

## Phone auth
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

############
# Studio dashboard — SUPABASE_PUBLIC_URL aligned with KONG_HTTP_PORT remap
############
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
STUDIO_PORT=3000
SUPABASE_PUBLIC_URL=http://localhost:{{ arc_kong_http_port }}
IMGPROXY_ENABLE_WEBP_DETECTION=true
OPENAI_API_KEY=

############
# Functions
############
FUNCTIONS_VERIFY_JWT=false

############
# Logflare (analytics — random tokens)
############
LOGFLARE_PUBLIC_ACCESS_TOKEN={{ lookup('password', '/dev/null length=32 chars=ascii_letters,digits') }}
LOGFLARE_PRIVATE_ACCESS_TOKEN={{ lookup('password', '/dev/null length=32 chars=ascii_letters,digits') }}

############
# Misc
############
DOCKER_SOCKET_LOCATION=/var/run/docker.sock
GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER
