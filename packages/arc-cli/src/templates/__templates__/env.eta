# .env — generated by `arc deploy` for project "<%= it.cfg.project %>"
# DO NOT EDIT BY HAND for the generated keys. Replace `__REPLACE_ME__`
# placeholders with real values before the first deploy.

BASE_DOMAIN=<%= it.cfg.domain %>
ADMIN_EMAIL=<%= it.cfg.email %>

# Cloudflare DNS
CF_API_TOKEN=<%= it.cfg.dns.api_token %>

# Generated at install time — replace before first deploy
JWT_SECRET=__REPLACE_ME__
POSTGRES_PASSWORD=__REPLACE_ME__

# Sandbox IDE password (code-server) — see docker-compose.sandbox.yml
CODE_SERVER_PASSWORD=__REPLACE_ME__

# OpenClaw — AI gateway routing
OPENCLAW_DEFAULT_MODEL=mistral:7b
OPENCLAW_FALLBACK_MODEL=__REPLACE_ME__

# External AI providers (used by OpenClaw fallback)
OPENAI_API_KEY=__REPLACE_ME__
ANTHROPIC_API_KEY=__REPLACE_ME__
