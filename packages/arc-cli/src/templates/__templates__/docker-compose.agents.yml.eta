# docker-compose.agents.yml — generated by `arc deploy` for project "<%= it.cfg.project %>"
# DO NOT EDIT BY HAND. Re-run `arc deploy` to regenerate.
#
# Adds the AI agent layer (OpenClaw + DeepAgents) on top of the
# `local-ai-packaged` bundle. Both networks are declared `external` —
# `ai_net` is created by local-ai-packaged, `sandbox_net` by the
# compose generated in CLI-007. `arc deploy` is responsible for the
# bring-up order.
#
# `deepagents` is the only service explicitly attached to BOTH
# `ai_net` and `sandbox_net`. This is the documented junction point
# of ADR-0008: the agent stays on `ai_net` to talk to OpenClaw and
# Qdrant, but reaches into the otherwise-isolated `sandbox_net` via
# `docker exec` to run the code it generates.
version: "3.9"

networks:
  ai_net:
    external: true
  sandbox_net:
    external: true

services:
  openclaw:
    image: ghcr.io/openclaw/openclaw:latest
    container_name: arc-openclaw
    restart: unless-stopped
    environment:
      OLLAMA_BASE_URL: http://ollama:11434
      DEFAULT_MODEL: ${OPENCLAW_DEFAULT_MODEL}
      FALLBACK_MODEL: ${OPENCLAW_FALLBACK_MODEL}
      OPENAI_API_KEY: ${OPENAI_API_KEY}
      ANTHROPIC_API_KEY: ${ANTHROPIC_API_KEY}
    labels:
      - traefik.enable=true
      - traefik.http.routers.openclaw.rule=Host(`openclaw.<%= it.cfg.domain %>`)
      - traefik.http.routers.openclaw.tls.certresolver=letsencrypt
      - traefik.http.services.openclaw.loadbalancer.server.port=3100
    networks:
      - ai_net

  deepagents:
    image: deepagents/deepagents:latest
    container_name: arc-deepagents
    restart: unless-stopped
    environment:
      LLM_PROVIDER: openclaw
      OPENCLAW_URL: http://openclaw:3100
      QDRANT_URL: http://qdrant:6333
    labels:
      - traefik.enable=true
      - traefik.http.routers.agents.rule=Host(`agents.<%= it.cfg.domain %>`)
      - traefik.http.routers.agents.tls.certresolver=letsencrypt
      - traefik.http.services.agents.loadbalancer.server.port=3200
    depends_on:
      - openclaw
    networks:
      - ai_net
      - sandbox_net
