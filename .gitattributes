# Normalize all text files to LF in the index and on checkout.
# Avoids CRLF/LF churn between Linux/macOS contributors and Windows.

* text=auto eol=lf

# Explicit binary types (no diff, no eol normalization).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
